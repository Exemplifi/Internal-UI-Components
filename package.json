{
  "name": "northernwaters",
  "private": true,
  "version": "0.0.0",
  "description": "Dev (SCSS + JS): npm run watch:dist — Sass watch + Vite --watch → src/assets/dist (static HTML). npm run dev:watch — Vite dev + Sass watch. Release: npm run build:all.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "watch:scss": "sass --watch --style=compressed --load-path=node_modules --load-path=src/assets/scss src/assets/scss/styles.scss src/assets/css/styles.css",
    "sass:build": "sass --style=compressed --load-path=node_modules --load-path=src/assets/scss src/assets/scss/styles.scss src/assets/css/styles.css",
    "build:js": "vite build --config vite.config.js --mode production",
    "build:all": "npm run sass:build && npm run build:js",
    "watch:vite": "vite build --watch --config vite.config.js --mode production",
    "watch:dist": "run-p watch:scss watch:vite",
    "dev:watch": "run-p dev watch:scss"
  },
  "devDependencies": {
    "figma-developer-mcp": "^0.11.0",
    "npm-run-all": "^4.1.5",
    "vite": "^6.4.1"
  },
  "dependencies": {
    "@popperjs/core": "^2.11.8",
    "aos": "^2.3.4",
    "bootstrap": "^5.3.6",
    "breakpoint-sass": "^3.0.0",
    "bs5-lightbox": "^1.8.5",
    "jquery": "^3.7.1",
    "lucide": "^0.514.0",
    "sass": "^1.89.2",
    "sass-rem": "^4.0.0",
    "slick-carousel": "^1.8.1",
    "swiper": "^12.1.4"
  }
}
